# ──────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────────
#  Firebase Admin SDK
#  Option A: Path to the service-account JSON file
#  Option B: Inline credentials (set all three)
# ──────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# — OR —
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ──────────────────────────────────────────────
#  Cloudinary
# ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────────
#  Google Gemini API (Preprocessing Intelligence)
# ──────────────────────────────────────────────
GEMINI_API_KEY=

# ──────────────────────────────────────────────
#  KIE API (Primary Image Generation Engine)
# ──────────────────────────────────────────────
KIE_API_URL=
KIE_API_KEY=
KIE_TIMEOUT_MS=120000
